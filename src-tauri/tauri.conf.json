{
  "build": {
    "beforeBuildCommand": "npm install && npm run build",
    "beforeDevCommand": "npm install && npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "POSPro",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.pospro.desktop",
      "resources": [],
      "windows": [
        {
          "title": "POSPro",
          "resizable": true,
          "fullscreen": false,
          "maximized": false
        }
      ]
    },
    "security": {
      "csp": null,
      "devUnsafeEval": true
    },
    "updater": {
      "active": false
    }
  }
}
